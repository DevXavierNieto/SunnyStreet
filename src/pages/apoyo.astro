---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
// Usamos la misma imagen del hero principal
import heroImage from '../assets/hero-full.jpg'; 
---

<Layout>
  <div class="page-flex">
    <Navbar />
    
    <main class="main-content">
      <section class="apoyo-hero">
        <Image src={heroImage} alt="Fondo Sunny Street" class="hero-bg-img" />
        
        <div class="hero-text-overlay">
          <h1>AYUDA A CONSTRUIR SUNNY STREET</h1>
          <p>Apoya a los creadores indie y desbloquea contenido exclusivo.</p>
        </div>
      </section>

      <section class="apoyo-cards-section">
        <div class="apoyo-grid">
          
          <div class="apoyo-card">
            <div class="card-icons-row">
              <img src="/imgs/icons/paypal-logo.png" alt="PayPal" class="paypal-logo" />
            </div>
            <h3>DONA DIRECTAMENTE EN PAYPAL</h3>
            <div class="button-group">
              <a href="#" class="btn-yellow">DONAR CON PAYPAL</a>
            </div>
          </div>

          <div class="apoyo-card metas-card">
            <h3>Metas de Financiación.</h3>
            <div class="progress-container">
              <span>Barra de progreso limpia</span>
              <div class="progress-bar">
                <div class="progress-fill" style="width: 65%;">65% lleno</div>
              </div>
            </div>
            <div class="meta-item">
              <img src="/imgs/vecinos/bruno.jpeg" alt="Meta 1" class="meta-icon" />
              <div>
                <strong>Meta $500:</strong>
                <p>Corto exclusivo de Bruno (reparaciones)</p>
              </div>
            </div>
            <div class="meta-item">
              <img src="/imgs/icons/archive-icon.png" alt="Meta 2" class="meta-icon" />
              <div>
                <strong>Meta $1000:</strong>
                <p>Arte conceptual del Archivo Secreto</p>
              </div>
            </div>
          </div>

          <div class="apoyo-card tienda-card">
            <div class="shop-icon-container">
              <img src="/imgs/icons/shop-icon.png" alt="Tienda" class="shop-icon" />
            </div>
            <h3>COMPRA MERCH PARA APOYAR LA PRODUCCIÓN</h3>
            <a href="/tienda" class="btn-yellow">IR A LA TIENDA</a>
          </div>

        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>

<style>
  .page-flex { display: flex; flex-direction: column; min-height: 100vh; }
  .main-content { flex: 1; background-color: #f8f9fa; }

  /* ESTILOS DEL HERO FULL-WIDTH */
  .apoyo-hero {
    position: relative;
    width: 100%;
    height: 400px; /* Altura controlada para el banner */
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-bg-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover; /* Cubre todo el ancho sin deformarse */
    z-index: 1;
  }

  .hero-text-overlay {
    position: relative;
    z-index: 2;
    text-align: center;
    color: white; /* Texto blanco para resaltar sobre el fondo azul */
    padding: 20px;
    max-width: 800px;
    text-shadow: 0 2px 10px rgba(0,0,0,0.3); /* Sombra para legibilidad */
  }

  .hero-text-overlay h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .hero-text-overlay p {
    font-size: 1.2rem;
    font-weight: 500;
  }

  /* GRID DE TARJETAS Y OVERLAP */
  .apoyo-cards-section {
    max-width: 1200px;
    margin: -60px auto 5rem auto; /* Overlap sobre la imagen del hero */
    padding: 0 20px;
    position: relative;
    z-index: 10;
  }

  .apoyo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .apoyo-card {
    background: white;
    border-radius: 20px;
    padding: 2.5rem 2rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    border: 1px solid #eee;
  }

  .apoyo-card h3 {
    font-size: 1rem;
    font-weight: 800;
    margin: 1.5rem 0;
    color: #333;
    line-height: 1.3;
  }

  .btn-yellow {
    background-color: #FACA5B;
    color: #1A1A1A;
    padding: 0.8rem 1.5rem;
    border-radius: 10px;
    text-decoration: none;
    font-weight: 800;
    font-size: 0.9rem;
    transition: transform 0.2s;
  }

  .btn-yellow:hover { transform: scale(1.05); }

  /* Elementos específicos de las tarjetas */
  .paypal-logo { height: 45px; width: auto; margin-bottom: 10px; }
  .metas-card { align-items: flex-start; text-align: left; }
  .progress-bar {
    width: 100%;
    background: #eee;
    height: 25px;
    border-radius: 15px;
    margin: 10px 0 20px 0;
    overflow: hidden;
  }
  .progress-fill {
    background: #A1D6E2;
    height: 100%;
    display: flex;
    align-items: center;
    padding-left: 15px;
    font-size: 0.75rem;
    font-weight: 800;
    color: white;
  }
  .meta-item { display: flex; align-items: center; gap: 12px; margin-bottom: 1rem; }
  .meta-icon { width: 40px; height: 40px; border-radius: 50%; border: 2px solid #FACA5B; object-fit: cover; }
  .shop-icon { height: 70px; margin-bottom: 10px; }

  @media (max-width: 1024px) {
    .apoyo-grid { grid-template-columns: 1fr; }
    .apoyo-hero { height: 300px; }
    .apoyo-cards-section { margin-top: 2rem; }
  }
</style>