---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import NeighborCard from '../components/NeighborCard.astro';
import { Image } from 'astro:assets';
import heroImage from '../assets/hero-full.jpg';

const vecinos = [
  { name: "Sunny", role: "Sin clasificar aún", image: "/imgs/vecinos/sunny.jpeg", info: "Es un chico alegre, carismático y muy perfeccionista. Es quien mantiene el ambiente del vecindario lleno de energía." },
  { name: "Rex", role: "Sin clasificar aún", image: "/imgs/vecinos/rex.jpeg", info: "Es tranquilo, inteligente y observador, alguien en quien puedes confiar. Es el dueño de la frutería del vecindario." },
  { name: "Deisy", role: "Sin clasificar aún", image: "/imgs/vecinos/deisy.jpeg", info: "Es dulce, optimista y amabre. Es la dueña de la pastelería del vecindario." },
  { name: "Aurora", role: "Sin clasificar aún", image: "/imgs/vecinos/aurora.jpeg", info: "Es emocional y muy expresiva. Es la encargada de la dulcería del vecindario." },
  { name: "Lysera", role: "Sin clasificar aún", image: "/imgs/vecinos/lysera.jpeg", info: "Es tranquila, dulce y conectada con la naturaleza. Es la duela de la florería." },
  { name: "Bruno", role: "Sin clasificar aún", image: "/imgs/vecinos/bruno.jpeg", info: "Es fuerte, noble y siempre dispuesto a ayudar. Es el dueño del taller Repara todo Bruno." },
  { name: "Dorian", role: "Sin clasificar aún", image: "/imgs/vecinos/dorian.jpeg", info: "Es creativo, dramático y muy expresivo. Es el duelo del teatro." },
  { name: "Nico", role: "Sin clasificar aún", image: "/imgs/vecinos/nico.jpeg", info: "Es divertido, bromista y lleno de energía. Se encarga de la diversión en el vecindario." },
  { name: "Amelia", role: "Sin clasificar aún", image: "/imgs/vecinos/amelia.jpeg", info: "Es timida, dulce y muy creativa. Es la artista que pinta y decora todo el lugar." },
  { name: "Carla", role: "Sin clasificar aún", image: "/imgs/vecinos/carla.jpeg", info: "Es rápida, responsable y de carácter fuerte. Se encargada de entregar el correo de todo el del vecindario." },
  { name: "Lumina", role: "Sin clasificar aún", image: "/imgs/vecinos/lumina.jpeg", info: "Es sabia, amable y protectora. Es la maestra que guia y cuida a todos en el vecindario." },
];
---

<Layout>
  <div class="page-flex">
    <Navbar />
    
    <main class="main-content">
      <div class="hero-banner">
        <Image src={heroImage} alt="Sunny Street Hero" class="hero-img" />
      </div>

      <section class="vecinos-section">
        <h2 class="section-title">CONOCE A LOS VECINOS</h2>
        
        <div class="neighbors-grid">
          {vecinos.map((vecino) => (
            <NeighborCard 
              name={vecino.name} 
              role={vecino.role} 
              image={vecino.image} 
              info={vecino.info}
            />
          ))}
        </div>
      </section>

      <section class="info-section">
        <div class="info-grid">
          
          <div class="info-card history-card">
            <div class="info-text">
              <h2 class="info-title">LA HISTORIA</h2>
              <h3 class="info-subtitle">Detrás de Sunny Street</h3>
              <p>Descubre cómo nació este colorido vecindario y los secretos que guardan sus calles desde hace años.</p>
            </div>
            <img src="/imgs/vecinos/sunny.jpeg" alt="Sunny" class="history-img" />
          </div>

          <div class="info-card list-card">
            <div class="card-icon">
              <img src="/imgs/icons/time-and-date.png" alt="Calendario" class="icon-img" />
            </div>
            <h2 class="info-title-sm">Noticias y Novedades</h2>
            <div class="news-item">
              <p>Nueva actualización del mapa del vecindario disponible.</p>
              <span>21 ene. 2026</span>
            </div>
            <div class="news-item">
              <p>Preparativos para el festival de verano han comenzado.</p>
              <span>15 ene. 2026</span>
            </div>
          </div>

          <div class="info-card interaction-card">
            <div class="card-icon">
              <img src="/imgs/icons/bubble-chat.png" alt="Chat" class="icon-img" />
            </div>
            <h2 class="info-title-sm">Interacción y Teorías</h2>
            <p>¡Únete a nuestra comunidad para debatir sobre los misterios de Sunny Street!</p>
          </div>

        </div>
      </section>
    </main>

    <div id="neighborModal" class="modal-overlay">
      <div class="modal-content">
        <button id="closeModal" class="close-btn">&times;</button>
        <div class="modal-body">
          <div class="modal-left">
            <img id="modalImg" src="" alt="" />
          </div>
          <div class="modal-right">
            <h2 id="modalName"></h2>
            <span id="modalRole"></span>
            <hr />
            <p id="modalInfo"></p>
          </div>
        </div>
      </div>
    </div>

    <Footer />
  </div>
</Layout>

<script>
  const modal = document.getElementById('neighborModal');
  const cards = document.querySelectorAll('.neighbor-card');
  const closeBtn = document.getElementById('closeModal');

  const mImg = document.getElementById('modalImg') as HTMLImageElement;
  const mName = document.getElementById('modalName');
  const mRole = document.getElementById('modalRole');
  const mInfo = document.getElementById('modalInfo');

  cards.forEach(card => {
    card.addEventListener('click', () => {
      const name = card.getAttribute('data-name');
      const role = card.getAttribute('data-role');
      const img = card.getAttribute('data-image');
      const info = card.getAttribute('data-info');

      if (modal && mImg && mName && mRole && mInfo) {
        mImg.src = img || '';
        mName.innerText = name || '';
        mRole.innerText = role || '';
        mInfo.innerText = info || '';
        modal.classList.add('active');
        document.body.style.overflow = 'hidden'; // Evita scroll de fondo
      }
    });
  });

  const closeModal = () => {
    modal?.classList.remove('active');
    document.body.style.overflow = 'auto';
  };

  closeBtn?.addEventListener('click', closeModal);
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });
</script>

<style>
  /* Diseño Base */
  .page-flex { display: flex; flex-direction: column; min-height: 100vh; }
  .main-content { flex: 1; background-color: #f8f9fa; }
  .hero-banner { width: 100%; display: block; line-height: 0; }
  .hero-img { width: 100%; height: auto; display: block; }

  /* Cuadrícula de Vecinos (3 Columnas) */
  .vecinos-section {
    max-width: 1000px;
    margin: 0 auto;
    padding: 5rem 20px;
  }
  .section-title {
    text-align: center;
    font-size: 2rem;
    font-weight: 900;
    margin-bottom: 4rem;
  }
  .neighbors-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 35px;
  }

  /* Sección Info Inferior */
  .info-section { max-width: 1240px; margin: 0 auto 6rem auto; padding: 0 20px; }
  .info-grid { display: grid; grid-template-columns: 1.6fr 1fr 1fr; gap: 25px; }
  .info-card { background: white; border-radius: 20px; padding: 30px; box-shadow: 0 4px 20px rgba(0,0,0,0.04); border: 1px solid #eee; }
  .history-card { flex-direction: row; display: flex; align-items: center; gap: 25px; }
  .history-img { height: 140px; object-fit: contain; }
  .info-title { font-size: 1.8rem; font-weight: 900; }
  .info-subtitle { font-size: 1.1rem; font-weight: 700; margin: 5px 0 10px 0; }
  .info-card p { font-size: 0.9rem; color: #555; line-height: 1.6; }
  .icon-img { width: 32px; height: auto; }

  /* ESTILOS DEL MODAL */
  .modal-overlay {
    position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(0, 0, 0, 0.8); display: flex; align-items: center; justify-content: center;
    opacity: 0; pointer-events: none; transition: opacity 0.3s ease; z-index: 2000;
  }
  .modal-overlay.active { opacity: 1; pointer-events: auto; }
  .modal-content {
    background: white; width: 90%; max-width: 900px; border-radius: 25px;
    position: relative; display: flex; flex-direction: column; overflow: hidden;
    transform: scale(0.9); transition: transform 0.3s ease;
  }
  .modal-overlay.active .modal-content { transform: scale(1); }
  .close-btn {
    position: absolute; top: 20px; right: 20px; font-size: 2rem;
    border: none; background: none; cursor: pointer; z-index: 10;
  }
  .modal-body { display: flex; min-height: 450px; }
  .modal-left { flex: 1; background: #f9f9f9; display: flex; align-items: center; justify-content: center; padding: 40px; }
  .modal-left img { max-width: 100%; max-height: 350px; object-fit: contain; }
  .modal-right { flex: 1; padding: 50px; display: flex; flex-direction: column; justify-content: center; }
  .modal-right h2 { font-size: 2.5rem; font-weight: 900; margin-bottom: 5px; }
  .modal-right span { color: #FACA5B; font-weight: 800; text-transform: uppercase; }
  .modal-right hr { width: 50px; border: 2px solid #FACA5B; margin: 20px 0; border-radius: 2px; }

  /* Responsivo */
  @media (max-width: 1024px) {
    .neighbors-grid { grid-template-columns: repeat(2, 1fr); }
    .info-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 800px) {
    .modal-body { flex-direction: column; }
    .modal-right { padding: 30px; }
  }
</style>