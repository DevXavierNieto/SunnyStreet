<nav class="nb-wrapper">
  <div class="nb-container">
    <a href="/" class="nb-brand">
      <img src="/imgs/logos/logo.png" alt="Logo" class="nb-logo-img" />
      <span class="nb-brand-name">Sunny Street</span>
    </a>

    <div class="nb-menu-section">
      <div class="nb-nav-links">
        <a href="/">Inicio</a>
        <span class="nb-divider">|</span>
        <a href="/tienda">Tienda</a>
        <span class="nb-divider">|</span>
        <a href="/apoyo">Apoyo</a>
      </div>

      <div class="nb-lang-selector" id="langSelector">
        <button class="nb-lang-btn" id="langBtn" aria-expanded="false">
          <img src="/imgs/flags/bandera_es.png" alt="" class="nb-btn-flag" id="currentFlag" />
          <span id="currentLangText">ES</span>
          <span class="nb-chevron">▾</span>
        </button>
        
        <ul class="nb-lang-list" id="langList" hidden>
          <li class="nb-lang-item" data-value="es" data-flag="/imgs/flags/bandera_es.png">
            <img src="/imgs/flags/bandera_es.png" alt="" class="nb-item-flag" />
            <span>ES</span>
          </li>
          <li class="nb-lang-item" data-value="en" data-flag="/imgs/flags/bandera_en.png">
            <img src="/imgs/flags/bandera_en.png" alt="" class="nb-item-flag" />
            <span>EN</span>
          </li>
        </ul>
      </div>
    </div>
  </div>
</nav>

<script>
  const selector = document.querySelector('#langSelector');
  const btn = document.querySelector('#langBtn');
  const list = document.querySelector('#langList');
  const items = document.querySelectorAll('.nb-lang-item');
  const currentText = document.querySelector('#currentLangText');
  const currentFlag = document.querySelector('#currentFlag') as HTMLImageElement;

  if (selector && btn && list) {
    // Abrir / Cerrar
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const isHidden = list.hasAttribute('hidden');
      if (isHidden) {
        list.removeAttribute('hidden');
        btn.setAttribute('aria-expanded', 'true');
      } else {
        list.setAttribute('hidden', '');
        btn.setAttribute('aria-expanded', 'false');
      }
    });

    // Seleccionar opción
    items.forEach(item => {
      item.addEventListener('click', () => {
        const val = item.getAttribute('data-value');
        const flag = item.getAttribute('data-flag');
        
        if (currentText && currentFlag && val && flag) {
          currentText.textContent = val.toUpperCase();
          currentFlag.src = flag;
        }
        list.setAttribute('hidden', '');
        btn.setAttribute('aria-expanded', 'false');
      });
    });

    // Cerrar al hacer clic fuera
    document.addEventListener('click', () => {
      list.setAttribute('hidden', '');
      btn.setAttribute('aria-expanded', 'false');
    });
  }
</script>

